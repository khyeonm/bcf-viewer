{
  "name": "bcf-viewer",
  "version": "1.3.0",
  "description": "BCF (Binary VCF) viewer with colored bases, metadata, and pagination",
  "extensions": [
    "bcf"
  ],
  "entry": "index.js",
  "style": "style.css",
  "data_source": {
    "type": "docker",
    "image": "biocontainers/bcftools:v1.9-1-deb_cv1",
    "row_count": "bcftools view {file} | grep -c -v '^#'",
    "metadata": "bcftools view -h {file}",
    "rows": "bcftools view {file} | grep -v '^#' | sed -n '{start},{end}p'",
    "col_headers": [],
    "meta_parse": "vcf_style",
    "allow_nonzero_exit": false
  }
}
